<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/db_bg"
        android:scaleType="centerCrop"/>

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/dashboardToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"/>

    <!-- Scroll Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="160dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/acse_logo"/>

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Admin Dashboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/caramel"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Extra Class Requests -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardClassReq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/coffee">

                <TextView
                    android:id="@+id/btnExtraClass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ExtraClass Request's"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:padding="18dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Current Free -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCurrentFree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/brownie">

                <TextView
                    android:id="@+id/btnCurrentFree"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Find Free Classroom Now"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:padding="18dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Today Free -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTodayFree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/brownie">

                <TextView
                    android:id="@+id/btnTodayFree"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Today's Free Classroom Availability"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:padding="18dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Edit DB -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEditDB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/coffee">

                <TextView
                    android:id="@+id/btnEditDB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit Database"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:padding="18dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Classroom Heading -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose a Classroom"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/light_caramel"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"/>

            <!-- Classroom Spinner -->
            <Spinner
                android:id="@+id/spinnerClassroom"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:spinnerMode="dropdown"
                android:background="@drawable/spinner_dashboard"
                android:layout_marginBottom="20dp"/>

            <!-- Classroom Schedule -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardClassrooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/brownie">

                <TextView
                    android:id="@+id/btnClassrooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Classroom's Schedule"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:padding="18dp"/>
            </androidx.cardview.widget.CardView>

            <!-- Section Heading -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose a Section"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/light_caramel"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"/>

            <!-- Section Spinner -->
            <Spinner
                android:id="@+id/spinnerSection"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:spinnerMode="dropdown"
                android:background="@drawable/spinner_dashboard"
                android:layout_marginBottom="20dp"/>

            <!-- Today's Schedule -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTodayClasses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/brownie">

                <TextView
                    android:id="@+id/btnTodayClasses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Today's Schedule"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:padding="18dp"/>
            </androidx.cardview.widget.CardView>

            <!-- View Timetable -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewTimetable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/brownie">

                <TextView
                    android:id="@+id/btnViewTimetable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View Section Timetable"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:padding="18dp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>